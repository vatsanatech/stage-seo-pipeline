{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["src/types", "node_modules/@types"],
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"]
}
